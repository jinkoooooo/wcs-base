<?xml version="1.0" encoding="UTF-8"?>

<configuration>
	<include resource="org/springframework/boot/logging/logback/base.xml" />
	<jmxConfigurator />

	<!-- 파일 appender: UTF-8 + 날짜/용량 기준 롤링, INFO 이상 -->
	<appender name="dailyRollingFileAppender" class="ch.qos.logback.core.rolling.RollingFileAppender">

		<!--
			prudent=true
			- 다중 프로세스가 같은 로그 파일에 접근할 수 있는 안전 모드
			- 기존 프로젝트에서 정상 사용 중인 기준으로 유지
			- prudent 사용 시 <file>logs/application.log</file> 지정하지 않는 방식이 적합
		-->
		<prudent>true</prudent>

		<!--
			날짜 + 용량 기준 로그 분할
			예시:
			logs/application.2026-04-24.0.log
			logs/application.2026-04-24.1.log
			logs/application.2026-04-24.2.log
		-->
		<rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
			<fileNamePattern>logs/application.%d{yyyy-MM-dd}.%i.log</fileNamePattern>
			<maxFileSize>100MB</maxFileSize>
			<maxHistory>30</maxHistory>
			<totalSizeCap>10GB</totalSizeCap>
		</rollingPolicy>

		<!-- INFO 이상만 파일 기록 -->
		<filter class="ch.qos.logback.classic.filter.ThresholdFilter">
			<level>INFO</level>
		</filter>

		<encoder>
			<charset>UTF-8</charset>
			<pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} %-5level [%thread] %logger{36}.%M\(%L\) - %msg%n</pattern>
		</encoder>
	</appender>

	<!-- Framework / Library 로그 레벨 -->
	<logger name="org.h2.server.web" level="INFO" />
	<logger name="org.hibernate.SQL" level="ERROR" />
	<logger name="org.springframework.web" level="INFO" />
	<logger name="org.springframework.jms.listener" level="WARN" />
	<logger name="org.springframework.web.socket.config" level="WARN" />
	<logger name="org.springframework.boot.context.embedded.FilterRegistrationBean" level="WARN" />
	<logger name="org.springframework.web.servlet.mvc.method.annotation.RequestMappingHandlerMapping" level="WARN" />
	<logger name="org.springframework.boot.autoconfigure.security.AuthenticationManagerConfiguration" level="WARN" />
	<logger name="de.codecentric.boot.admin.services.SpringBootAdminRegistrator" level="ERROR" />
	<logger name="org.apache.activemq.broker.BrokerService" level="ERROR" />

	<!-- Business Package 로그 레벨 -->
	<logger name="xyz.elidom" level="DEBUG" />

	<!-- Root Logger: 파일 기록 -->
	<root level="INFO">
		<appender-ref ref="dailyRollingFileAppender" />
	</root>
</configuration>